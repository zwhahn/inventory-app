<html>
  <head>
    <title>Inventory App</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <h1>Edit: <%= product.name %></h1>
    <form method="POST" action="/edit">
      <label for="item">Item:</label>
      <input type="text" id="item" name="item" value="<%=product.name%>"/>

      <label for="description">Description:</label>
      <input type="text" id="description" name="description" value="<%=product.description%>"/>

      <label for="quantity">Stock Quantity:</label>
      <input type="number" min="0" step="1" id="quantity" name="quantity" value="<%=product.stock_quantity%>" />

      <label for="price">Price (USD):</label>
      <input type="number" step="0.01" min="0" id="price" name="price" value="<%=product.price%>"/>

      <label for="category">Category:</label>
      <select name="category_id" id="category_id">
        <% categories.forEach(category => { %>
          <option 
          value="<%=category.id%>" 
          <%= category.id === product.category_id ? 'selected' : '' %>
          >
          <%= category.category %></option>
        <% }) %>
      </select>
    </form>
  </body>
</html>
